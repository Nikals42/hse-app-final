// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                Int                  @id @default(autoincrement())
  name              String               @unique
  leadingIndicators HSE_Report[]
  laggingIndicators Lagging_Indicators[]
}

model Contractors {
  id                Int                  @id @default(autoincrement())
  name              String               @unique
  leadingIndicators HSE_Report[]
  laggingIndicators Lagging_Indicators[]
}

model HSE_Report {
  id                Int      @id @default(autoincrement())
  projectId         Int      @default(0)
  contractorId      Int      @default(0)
  HSEAudits         Int      @default(0)
  safetyWalks       Int      @default(0)
  toolboxTalks      Int      @default(0)
  workingHours      Int      @default(0)
  trainingHours     Float    @default(0)
  jobSafetyAnalysis Int      @default(0)
  timeStamp         DateTime

  project    Project     @relation(fields: [projectId], references: [id])
  contractor Contractors @relation(fields: [contractorId], references: [id])
}

model Lagging_Indicators {
  id           Int      @id @default(autoincrement())
  projectId    Int      @default(0)
  contractorId Int      @default(0)
  LWC          Int      @default(0)
  FA           Int      @default(0)
  MTI          Int      @default(0)
  RTW          Int      @default(0)
  Fatality     Int      @default(0)
  PPD          Int      @default(0)
  PTD          Int      @default(0)
  timeStamp    DateTime

  project    Project     @relation(fields: [projectId], references: [id])
  contractor Contractors @relation(fields: [contractorId], references: [id])
}

model Accounts {
  id       Int    @id @default(autoincrement())
  username String @unique
}

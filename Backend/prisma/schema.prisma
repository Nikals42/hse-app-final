generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id Int @id
  name String
  data HSE_Report[]
}

model HSE_Report {
  id Int @id @default(autoincrement())
  projectId Int
  projectName String
  HSEAudits Int
  safetyWalks Int
  toolboxTalks Int
  workingHours Int
  trainingHours Int
  jobSafetyAnalysis Int
  
  timeStamp DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id])
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id Int @id @default(autoincrement())
  name String @unique
  leadingIndicators HSE_Report[]
  laggingIndicators Lagging_Indicators[]
}

model HSE_Report {
  id Int @id @default(autoincrement())
  projectId Int
  timeStamp DateTime @default(now())
  HSEAudits Int
  safetyWalks Int
  toolboxTalks Int
  workingHours Int
  trainingHours Int
  jobSafetyAnalysis Int
  
  project Project @relation(fields: [projectId], references: [id])
}

model Lagging_Indicators {
  id Int @id @default(autoincrement())
  projectId Int @unique
  LTI Int
  FA Int
  MTI Int
  RTW Int
  Fatality Int
  PPD Int
  PTD Int

  project Project @relation(fields: [projectId], references: [id])
}

model Accounts {
  id Int @id @default(autoincrement())
  username String @unique
}